        # Syntax Highlighting
        lexer = XmlLexer()
        formatter = HtmlFormatter()
        highlighted_code = HTMLHighlighter(lexer, formatter).highlight(code)

        # Auto-Completion
        script = Script(code)
        completions = [c.description for c in script.completions()]

        # Error Checking
        errors = []
