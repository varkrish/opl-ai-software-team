            minidom.parseString(code)
        except Exception as e:
            errors.append(str(e))

        # Validation
        valid = len(errors) == 0

        return {
            'highlighted_code': highlighted_code,
            'suggestions': completions,
            'errors': errors,
            'is_valid': valid
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

