# ─────────────────────────────────────────────────────────────────────────────
# AI Crew Studio — Backend (Flask + LlamaIndex)
# Podman / Docker compatible
# ─────────────────────────────────────────────────────────────────────────────
FROM registry.access.redhat.com/ubi9/python-311:latest AS base

# Labels (OCI standard)
LABEL org.opencontainers.image.title="AI Crew Studio — Backend"
LABEL org.opencontainers.image.description="Flask API backend for AI Software Development Crew"
LABEL org.opencontainers.image.vendor="Red Hat"
LABEL org.opencontainers.image.licenses="MIT"

# Switch to root for system packages
USER root

# Install system deps (git needed by gitpython, Node.js for Repomix)
# Note: curl-minimal is pre-installed on UBI9; do NOT install curl (conflicts)
RUN dnf install -y --nodocs \
        git \
        gcc \
        gcc-c++ \
        make \
        nodejs \
        npm \
    && dnf clean all \
    && rm -rf /var/cache/dnf

WORKDIR /app

# ── Python dependencies ──────────────────────────────────────────────────────
COPY agent/pyproject.toml /app/agent/pyproject.toml

# Install dependencies first (layer cache)
RUN cd /app/agent && \
    pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -e . 2>/dev/null || \
    pip install --no-cache-dir \
        "fastapi>=0.115.0" \
        "uvicorn[standard]>=0.30.0" \
        "PyJWT>=2.8.0" \
        "llama-index>=0.10.0" \
        "llama-index-core>=0.10.0" \
        "llama-index-agent-openai>=0.2.0" \
        "llama-index-llms-openai>=0.1.0" \
        "llama-index-llms-anthropic>=0.1.0" \
        "llama-index-llms-ollama>=0.1.0" \
        "llama-index-embeddings-openai>=0.1.0" \
        "llama-index-embeddings-huggingface>=0.1.0" \
        "gitpython>=3.1.43" \
        "PyYAML>=6.0.2" \
        "rich>=13.9.4" \
        "python-dotenv>=1.0.1" \
        "requests>=2.32.3" \
        "flask>=3.0.0" \
        "flask-cors>=4.0.0" \
        "jsonschema[format]>=4.0.0" \
        "litellm>=1.0.0" \
        "cryptography>=41.0.0" \
        "httpx>=0.28.0"

# ── Copy application source ──────────────────────────────────────────────────
COPY agent/src/ /app/agent/src/

# Copy the entire crew_studio package (web app, job DB, refinement runner, etc.)
COPY crew_studio/ /app/crew_studio/

# Make agent package importable
RUN cd /app/agent && pip install --no-cache-dir -e . 2>/dev/null || true

# Optional code-intelligence CLI — not a pyproject dep; runtime no-ops if missing/disabled.
# Install CLI-only (--no-deps): llm-tldr pulls anthropic>=0.75 which conflicts with
# llama-index-llms-anthropic (<0.29). We only subprocess tldr structure/search/context/impact.
RUN pip install --no-cache-dir "llm-tldr>=1.2.0" --no-deps && \
    pip install --no-cache-dir \
        "pygments-tldr>=2.19.1.3" \
        "pathspec>=0.12.0" \
        "requests>=2.25.0" \
        "rich>=14.2.0" \
        "tree-sitter>=0.23.0" \
        "tree-sitter-python>=0.23.0" \
        "tree-sitter-typescript>=0.23.0" \
        "tree-sitter-javascript>=0.25.0" \
        "tree-sitter-go>=0.25.0" \
        "tree-sitter-rust>=0.24.2" \
        "tree-sitter-java>=0.23.5" \
        "tree-sitter-c>=0.24.2" \
        "tree-sitter-cpp>=0.23.4" \
        "tree-sitter-ruby>=0.23.1" \
        "tree-sitter-php>=0.24.1" \
        "tree-sitter-c-sharp>=0.23.5" \
        "tree-sitter-kotlin>=1.1.0" \
        "tree-sitter-scala>=0.26.0" \
        "tree-sitter-lua<=0.4.1" \
        "tree-sitter-luau" \
        "tree-sitter-elixir>=0.3.0"

# ── Download NLTK data (required by LlamaIndex) ──────────────────────────────
RUN mkdir -p /app/nltk_data && \
    python -c "import nltk; nltk.data.path.insert(0, '/app/nltk_data'); nltk.download('punkt', download_dir='/app/nltk_data'); nltk.download('averaged_perceptron_tagger', download_dir='/app/nltk_data')" && \
    chmod -R 755 /app/nltk_data

# ── Pre-download HuggingFace embedding model ──────────────────────────────────
# Bake the model into the image so the container never needs internet access at runtime.
# /app/hf_cache is owned by 1001:0 so the non-root user can read it.
RUN HF_HOME=/app/hf_cache python -c "\
from llama_index.embeddings.huggingface import HuggingFaceEmbedding; \
HuggingFaceEmbedding(model_name='BAAI/bge-small-en-v1.5'); \
print('BAAI/bge-small-en-v1.5 cached OK')"

# ── Create directories ───────────────────────────────────────────────────────
RUN mkdir -p /app/workspace /app/data && \
    chown -R 1001:0 /app && \
    chmod -R g=u /app

# ── Environment ──────────────────────────────────────────────────────────────
ENV PYTHONPATH=/app/agent:/app/agent/src:/app \
    PYTHONUNBUFFERED=1 \
    NLTK_DATA=/app/nltk_data \
    HF_HOME=/app/hf_cache \
    WORKSPACE_PATH=/app/workspace \
    JOB_DB_PATH=/app/data/crew_jobs.db \
    FLASK_ENV=production \
    PORT=8080

# Run as non-root (OpenShift compatible)
USER 1001

EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -sf http://localhost:8080/health || exit 1

# ── Entrypoint ───────────────────────────────────────────────────────────────
CMD ["python", "-m", "uvicorn", "crew_studio.asgi_app:app", "--host", "0.0.0.0", "--port", "8080"]
